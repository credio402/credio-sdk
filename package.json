{
  "name": "credio-sdk",
  "version": "0.1.0",
  "description": "Credit layer for AI agents on x402 (Base). Front USDC for your agent's x402 payments and repay on-chain — non-custodial, no API keys.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "x402",
    "base",
    "ai-agents",
    "agent-economy",
    "usdc",
    "credit",
    "payments",
    "credio"
  ],
  "homepage": "https://credio.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CredioX402/credio-sdk.git"
  },
  "bugs": { "url": "https://github.com/CredioX402/credio-sdk/issues" },
  "license": "MIT",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
